# ─────────────────────────────────────────────────────────────────────────────
# Ashraak — Environment Variables Template
#
# Instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in all values marked  ← REQUIRED
#   3. The .env file is git-ignored — NEVER commit it.
#
# Production secrets strategy:
#   Do NOT use .env files in production.
#   Inject variables via your CI/CD pipeline (GitHub Actions, GitLab CI),
#   Docker Swarm secrets, or a secrets manager (HashiCorp Vault, AWS Secrets
#   Manager, Azure Key Vault).
# ─────────────────────────────────────────────────────────────────────────────


# ── API ───────────────────────────────────────────────────────────────────────

# Host port the API container binds to.
API_PORT=8080

# Published image tag (used by docker-compose.prod.yml).
API_VERSION=latest

# ASP.NET Core environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Production


# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Database credentials  ← REQUIRED (change from defaults in all non-dev envs)
POSTGRES_USER=ashraak
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION      # ← REQUIRED
POSTGRES_DB=ashraak

# Service name inside Docker network (do not change unless renaming the service)
POSTGRES_HOST=postgres

# Host port — change if 5432 conflicts with a local PostgreSQL installation
POSTGRES_PORT=5432


# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_HOST=redis
REDIS_PORT=6379
# Empty password is acceptable in dev (no authentication).
# Must be a strong password in production.
REDIS_PASSWORD=                                 # ← REQUIRED in production


# ── MongoDB ───────────────────────────────────────────────────────────────────

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=ashraak
MONGO_PASSWORD=CHANGE_ME_IN_PRODUCTION          # ← REQUIRED
MONGO_DB=ashraak_audit


# ── RabbitMQ ──────────────────────────────────────────────────────────────────

RABBITMQ_USER=ashraak
RABBITMQ_PASSWORD=CHANGE_ME_IN_PRODUCTION       # ← REQUIRED
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672


# ── Seq (structured log viewer) ───────────────────────────────────────────────

SEQ_HOST=seq
SEQ_PORT=5341
# Generate with: docker run --rm datalust/seq config hash --password=YourPassword
SEQ_ADMIN_PASSWORD_HASH=                        # ← REQUIRED in production


# ── JWT / OpenIddict ──────────────────────────────────────────────────────────

# Base64-encoded 256-bit HMAC key used by OpenIddict to sign tokens.
# Generate with: openssl rand -base64 32
# In production, use a proper X.509 certificate and remove this variable.
JWT_SIGNING_KEY_BASE64=CHANGE_ME_BASE64_32_BYTES_MIN  # ← REQUIRED


# ── Google SSO ────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Microsoft (Entra ID) SSO ──────────────────────────────────────────────────

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
