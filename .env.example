# ─────────────────────────────────────────────────────────────────────────────
# CCTVCRM / Ashraak — Integrated Local Test Environment Variables
#
# Instructions:
#   1. Copy:  cp .env.example .env
#   2. For local dev, the defaults below work with docker-compose.override.yml
#   3. NEVER commit .env — it is git-ignored
#
# Run from repository root:
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────


# ── API ───────────────────────────────────────────────────────────────────────

API_PORT=8080
API_VERSION=latest
ASPNETCORE_ENVIRONMENT=Development


# ── Web SPA (React / Vite) ────────────────────────────────────────────────────

# Host port mapped to the web container.
WEB_PORT=3000

# Internal container port (3000 = Vite dev, 80 = nginx production).
WEB_CONTAINER_PORT=3000

# Docker build target: development | production
WEB_BUILD_TARGET=development
WEB_VERSION=latest

# Used by Vite dev-server proxy (container-to-container DNS).
# Browser traffic: http://localhost:3000 → proxy → ashraak-api:8080
VITE_API_BASE_URL=http://ashraak-api:8080
VITE_API_VERSION=v1
VITE_APP_NAME=Ashraak (Local)


# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_USER=ashraak
POSTGRES_PASSWORD=ashraak_dev
POSTGRES_DB=ashraak
POSTGRES_HOST=postgres
POSTGRES_PORT=5432


# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=


# ── MongoDB ───────────────────────────────────────────────────────────────────

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=ashraak
MONGO_PASSWORD=ashraak_dev
MONGO_DB=ashraak_audit


# ── RabbitMQ (infrastructure only — API not wired) ────────────────────────────

RABBITMQ_USER=ashraak
RABBITMQ_PASSWORD=ashraak_dev
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672


# ── Seq (structured log viewer) ───────────────────────────────────────────────

SEQ_HOST=seq
SEQ_PORT=5341
SEQ_ADMIN_PASSWORD_HASH=


# ── JWT / OpenIddict (dev-only key — rotate for non-local environments) ───────

JWT_SIGNING_KEY_BASE64=K7gNU3sdo+OL0wNhqoVWhr3g6s1xYv72ol/pe/Unols=
