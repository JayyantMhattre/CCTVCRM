# Copy this file to .env.development or .env.production and fill in values.
# All VITE_* variables are injected at build time via import.meta.env.

# Base URL of the backend REST API (no trailing slash).
# In development, Vite's dev server proxies /api and /connect to this URL
# so you can avoid CORS issues.
VITE_API_BASE_URL=http://localhost:5000

# API version prefix (e.g., v1, v2).
# Used by core/api/endpoints.ts to build versioned URLs automatically.
VITE_API_VERSION=v1

# Display name shown in the browser tab and app header.
VITE_APP_NAME=Ashraak
